<odoo>
    <!--    listview -->
    <record id="employee_loan_view_list" model="ir.ui.view">
        <field name="name">employee.loan.list</field>
        <field name="model">employee.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="installments"/>
                <field name="state"/>
            </list>
        </field>
    </record>

<!--    form view-->
<record id="employee_loan_view_form" model="ir.ui.view">
        <field name="name">employee.loan.form</field>
        <field name="model">employee.loan</field>
         <field name="arch" type="xml">
           <form>
               <header>
                   <button name="action_draft" string="Draft" type="object"
                           invisible="state != 'rejected'" />
                   <button name="action_confirm" string="Confirmed" type="object"
                           class="btn-primary"
                           invisible="state != 'draft'"  />
                   <button name="action_approve" string="Approved" type="object"
                           class="btn-primary" invisible="state != 'confirmed'" groups="employee_loan.group_loan_manager" />
                   <button name="action_reject" string="Rejected" type="object"
                           class="btn-danger" invisible="state != 'confirmed'"  groups="employee_loan.group_loan_manager"/>
                   <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved,rejected"/>
               </header>
               <sheet>
                   <group>
                <field name="name" readonly="1"/>
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="installments"/>
                <field name="notes"/>
                <field name="amount_paid" readonly="1"/>
                <field name="amount_remaining" readonly="1"/>
                   </group>
                   <notebook>
                        <page string="Installments">
                            <field name="loan_line_ids">
                                <list>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="state"
                                     readonly="parent.state != 'approved'"
                                     groups="employee_loan.group_loan_manager"/>

                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
               <chatter/>
           </form>
        </field>
</record>


        <!-- Search View -->
<record id="employee_loan_view_search" model="ir.ui.view">
    <field name="name">employee.loan.search</field>
    <field name="model">employee.loan</field>
    <field name="arch" type="xml">
        <search>
            <field name="name"/>
            <field name="employee_id"/>
            <separator/>
            <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
            <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
            <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
            <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
            <separator/>
            <group expand="0" string="Group By">
                <filter string="Employee" name="group_employee" context="{'group_by':'employee_id'}"/>
                <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
            </group>
        </search>
    </field>
</record>


            <!-- Kanban View -->
<record id="employee_loan_view_kanban" model="ir.ui.view">
    <field name="name">employee.loan.kanban</field>
    <field name="model">employee.loan</field>
    <field name="arch" type="xml">
        <kanban>
            <field name="name"/>
            <field name="employee_id"/>
            <field name="amount"/>
            <field name="amount_paid"/>
            <field name="amount_remaining"/>
            <field name="state"/>
            <templates>
                <t t-name="card">
                    <div class="fw-bold"><field name="name"/></div>
                    <div><field name="employee_id"/></div>
                    <div>Loan Amount: <field name="amount"/></div>
                    <div>Paid: <field name="amount_paid"/></div>
                    <div>Remaining: <field name="amount_remaining"/></div>
                    <div>Status: <field name="state"/></div>
                </t>
            </templates>
        </kanban>
    </field>
</record>


    <!--action-->
    <record id="employee_loan_action" model="ir.actions.act_window">
        <field name="name">Employee Loans</field>
    <field name="res_model">employee.loan</field>
    <field name="view_mode">list,kanban,form</field>
    </record>





    <!--menu -->
    <menuitem id="employee_loan_menue_root"
               name="Employee Loans"
               action="employee_loan_action"
               sequence="10"/>







</odoo>